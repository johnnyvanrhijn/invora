# ============================================================
# INVORA — Environment Variables Template
# ============================================================
# Kopieer dit bestand naar .env.local en vul de MVP-variabelen in.
# Commit NOOIT .env.local naar git.
#
# Legenda:
# [MVP]             = Nu invullen, app werkt niet zonder dit
# [BIJ 3 KLANTEN]   = Pas invullen bij mijlpaal 3 betalende klanten
# [BIJ 10 KLANTEN]  = Pas invullen bij start iOS app
# [OPTIONEEL]       = Feature werkt niet maar app wel
# ============================================================


# ============================================================
# SUPABASE [MVP]
# Aanmaken: supabase.com → jouw project → Settings → API
# ============================================================

# Project URL — Settings → API → Project URL
NEXT_PUBLIC_SUPABASE_URL=

# Anon public key — Settings → API → anon public
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Service role key — Settings → API → service_role
# NOOIT in frontend gebruiken
SUPABASE_SERVICE_ROLE_KEY=

# Database URI — Settings → Database → Connection string → URI
# Nodig voor Supabase CLI (migraties)
DATABASE_URL=


# ============================================================
# RESEND [MVP]
# Aanmaken: resend.com → API Keys → Create API Key
# ============================================================

RESEND_API_KEY=
RESEND_FROM_EMAIL=facturen@invora.nl


# ============================================================
# STRIPE [MVP]
# Aanmaken: dashboard.stripe.com → Developers → API keys
# Gebruik test keys (pk_test_ / sk_test_) tijdens ontwikkeling
# ============================================================

NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_SECRET_KEY=

# Webhook secret — lokaal via Stripe CLI: stripe listen
STRIPE_WEBHOOK_SECRET=

# Price ID — aanmaken in Stripe dashboard na product aanmaken
STRIPE_PRICE_ID=


# ============================================================
# MOLLIE [MVP]
# Aanmaken: mollie.com → Developers → API keys
# Dit is jouw eigen Mollie account voor testdoeleinden.
# Gebruikers koppelen hun eigen Mollie account via instellingen.
# ============================================================

MOLLIE_TEST_API_KEY=
MOLLIE_LIVE_API_KEY=

# Encryptie sleutel voor Mollie API keys van gebruikers (AES-256)
# Gebruikers slaan hun eigen Mollie key versleuteld op in users.mollie_api_key_encrypted
# Genereer met: openssl rand -hex 32
# LET OP: deze sleutel NOOIT roteren zonder eerst alle bestaande ciphertexts
# te decrypten en opnieuw te encrypten — anders verliezen gebruikers hun Mollie koppeling.
MOLLIE_ENCRYPTION_KEY=


# ============================================================
# KVK API [BIJ 3 KLANTEN — nu leeg laten]
# Aanmaken: developers.kvk.nl → Account + applicatie
# Vul pas in bij mijlpaal 3 betalende klanten
# ============================================================

KVK_API_KEY=
KVK_API_BASE_URL=https://developers.kvk.nl/test/api/v1


# ============================================================
# POSTCODE API [BIJ 3 KLANTEN — nu leeg laten]
# Aanmaken: postcodeapi.nu → Account + API key
# Vul pas in bij mijlpaal 3 betalende klanten
# ============================================================

POSTCODE_API_KEY=
POSTCODE_API_BASE_URL=https://api.postcodeapi.nu/v3/lookup


# ============================================================
# APP CONFIGURATIE [MVP]
# ============================================================

# Lokaal: http://localhost:3000 | Productie: https://invora.nl
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Geheime sleutel voor veilige betaalpagina tokens
# Genereer met: openssl rand -hex 32
INVOICE_TOKEN_SECRET=

# Geheime sleutel voor intern metrics dashboard
# Genereer met: openssl rand -hex 16
INTERNAL_DASHBOARD_SECRET=


# ============================================================
# ANALYTICS [OPTIONEEL — toevoegen voor productie]
# ============================================================

# Google Analytics 4 — analytics.google.com → Create property
# Formaat: G-XXXXXXXXXX
NEXT_PUBLIC_GA_MEASUREMENT_ID=

# Google Search Console verificatie token
NEXT_PUBLIC_GSC_VERIFICATION=


# ============================================================
# EXPO / iOS APP [BIJ 10 KLANTEN — nu nog niet nodig]
# Pas aanmaken als je begint met de iOS app
# ============================================================

# EXPO_PUBLIC_SUPABASE_URL=
# EXPO_PUBLIC_SUPABASE_ANON_KEY=
# EXPO_PUBLIC_APP_URL=https://invora.nl
